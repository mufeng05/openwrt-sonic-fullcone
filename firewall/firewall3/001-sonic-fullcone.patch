From: openwrt-sonic-fullcone contributors
Date: Wed, 9 Apr 2026 00:00:00 +0000
Subject: [PATCH] firewall3: add SONiC fullcone NAT with per-zone,
 per-protocol and per-source-IP control

Adds zone-level fullcone option with fullcone_proto and fullcone_src
lists to firewall3. defaults.fullcone is a global gate.

Uses native fw3 parse infrastructure (FW3_OPT / FW3_LIST) — no manual
uci_lookup_option calls. fullcone_proto reuses fw3_parse_protocol,
fullcone_src reuses fw3_parse_network (same as existing masq_src).

Requires the 901-sonic-fullcone iptables patch for --fullcone support.
---
 defaults.c |  2 ++
 options.h  |  5 +++
 zones.c    | 94 ++++++++++++++++++++++++++++++++++++++++++++++++++---
 3 files changed, 97 insertions(+), 4 deletions(-)

--- a/defaults.c
+++ b/defaults.c
@@ -46,6 +46,8 @@ const struct fw3_option fw3_flag_opts[]
 	FW3_OPT("synflood_protect",    bool,     defaults, syn_flood),
 	FW3_OPT("synflood_rate",       limit,    defaults, syn_flood_rate),
 	FW3_OPT("synflood_burst",      int,      defaults, syn_flood_rate.burst),
+
+	FW3_OPT("fullcone",           bool,     defaults, fullcone),

 	FW3_OPT("tcp_syncookies",      bool,     defaults, tcp_syncookies),
 	FW3_OPT("tcp_ecn",             int,      defaults, tcp_ecn),
--- a/options.h
+++ b/options.h
@@ -267,6 +267,7 @@ struct fw3_defaults
 	bool drop_invalid;

 	bool syn_flood;
+	bool fullcone;
 	struct fw3_limit syn_flood_rate;

 	bool tcp_syncookies;
@@ -340,6 +341,10 @@ struct fw3_zone

 	bool mtu_fix;

+	bool fullcone;
+	struct list_head fullcone_proto;
+	struct list_head fullcone_src;
+
 	struct list_head cthelpers;

 	int log;
--- a/zones.c
+++ b/zones.c
@@ -84,7 +84,11 @@ const struct fw3_option fw3_zone_opts[]

 	FW3_OPT("mtu_fix",             bool,     zone,     mtu_fix),
 	FW3_OPT("custom_chains",       bool,     zone,     custom_chains),

+	FW3_OPT("fullcone",            bool,     zone,     fullcone),
+	FW3_LIST("fullcone_proto",     protocol, zone,     fullcone_proto),
+	FW3_LIST("fullcone_src",       network,  zone,     fullcone_src),
+
 	FW3_OPT("log",                 int,      zone,     log),
 	FW3_OPT("log_limit",           limit,    zone,     log_limit),

@@ -214,7 +218,9 @@ fw3_alloc_zone(void)
 	INIT_LIST_HEAD(&zone->masq_src);
 	INIT_LIST_HEAD(&zone->masq_dest);
 	INIT_LIST_HEAD(&zone->cthelpers);
+	INIT_LIST_HEAD(&zone->fullcone_proto);
+	INIT_LIST_HEAD(&zone->fullcone_src);

 	INIT_LIST_HEAD(&zone->old_addrs);

 	zone->enabled = true;
@@ -627,6 +633,11 @@ print_zone_rule(struct fw3_ipt_handle *h
 	struct fw3_address *msrc;
 	struct fw3_address *mdest;
 	struct fw3_ipt_rule *r;
+	struct fw3_defaults *defs = &state->defaults;
+	struct fw3_protocol *proto;
+	struct fw3_address *fc_src;
+	bool zone_fullcone = defs->fullcone && zone->fullcone;
+	bool has_fc_filter = zone_fullcone && (!list_empty(&zone->fullcone_proto) || !list_empty(&zone->fullcone_src));

 	if (!fw3_is_family(zone, handle->family))
 		return;
@@ -755,9 +766,70 @@ print_zone_rule(struct fw3_ipt_handle *h
 				{
 					r = fw3_ipt_rule_new(handle);
 					fw3_ipt_rule_src_dest(r, msrc, mdest);
-					fw3_ipt_rule_target(r, "MASQUERADE");
-					fw3_ipt_rule_append(r, "zone_%s_postrouting", zone->name);
+					if (has_fc_filter)
+					{
+						/* Per-proto and/or per-src fullcone rules */
+						if (!list_empty(&zone->fullcone_proto)) {
+							list_for_each_entry(proto, &zone->fullcone_proto, list) {
+								if (!list_empty(&zone->fullcone_src)) {
+									list_for_each_entry(fc_src, &zone->fullcone_src, list) {
+										if (!fw3_is_family(fc_src, handle->family))
+											continue;
+										r = fw3_ipt_rule_new(handle);
+										fw3_ipt_rule_src_dest(r, fc_src, mdest);
+										fw3_ipt_rule_proto(r, proto);
+										fw3_ipt_rule_target(r, "MASQUERADE");
+										fw3_ipt_rule_extra(r, "--fullcone");
+										fw3_ipt_rule_append(r, "zone_%s_postrouting", zone->name);
+									}
+								} else {
+									r = fw3_ipt_rule_new(handle);
+									fw3_ipt_rule_src_dest(r, msrc, mdest);
+									fw3_ipt_rule_proto(r, proto);
+									fw3_ipt_rule_target(r, "MASQUERADE");
+									fw3_ipt_rule_extra(r, "--fullcone");
+									fw3_ipt_rule_append(r, "zone_%s_postrouting", zone->name);
+								}
+							}
+						} else {
+							/* src-only filter */
+							list_for_each_entry(fc_src, &zone->fullcone_src, list) {
+								if (!fw3_is_family(fc_src, handle->family))
+									continue;
+								r = fw3_ipt_rule_new(handle);
+								fw3_ipt_rule_src_dest(r, fc_src, mdest);
+								fw3_ipt_rule_target(r, "MASQUERADE");
+								fw3_ipt_rule_extra(r, "--fullcone");
+								fw3_ipt_rule_append(r, "zone_%s_postrouting", zone->name);
+							}
+						}
+						/* Fallback masquerade for non-fullcone traffic.
+						 * Note: iptables MASQUERADE target only works in
+						 * POSTROUTING, so fw3 fullcone provides EIM only
+						 * (no EIF for unsolicited inbound). Use fw4 for
+						 * full EIM+EIF support.
+						 */
+						r = fw3_ipt_rule_new(handle);
+						fw3_ipt_rule_src_dest(r, msrc, mdest);
+						fw3_ipt_rule_target(r, "MASQUERADE");
+						fw3_ipt_rule_append(r, "zone_%s_postrouting", zone->name);
+					}
+					else if (zone_fullcone)
+					{
+						/* All traffic fullcone: POSTROUTING only
+						 * (MASQUERADE cannot be used in PREROUTING)
+						 */
+						fw3_ipt_rule_target(r, "MASQUERADE");
+						fw3_ipt_rule_extra(r, "--fullcone");
+						fw3_ipt_rule_append(r, "zone_%s_postrouting", zone->name);
+					}
+					else
+					{
+						/* Standard masquerade */
+						fw3_ipt_rule_target(r, "MASQUERADE");
+						fw3_ipt_rule_append(r, "zone_%s_postrouting", zone->name);
+					}
 				}
 			}
 		}
