From: openwrt-sonic-fullcone contributors
Date: Wed, 9 Apr 2026 00:00:00 +0000
Subject: [PATCH] firewall3: add SONiC fullcone NAT with per-zone,
 per-protocol and per-source-IP control

Adds zone-level fullcone option with fullcone_proto and fullcone_src
lists to firewall3. defaults.fullcone is a global gate.

Example config:
  config zone 'wan'
    option fullcone '1'
    list fullcone_proto 'udp'
    list fullcone_src '192.168.1.100'

Requires the 901-sonic-fullcone iptables patch for --fullcone support.
---
 defaults.c |  2 ++
 options.h  |  3 ++
 zones.c    | 80 +++++++++++++++++++++++++++++++++++++++++++++++++++
 3 files changed, 85 insertions(+)

--- a/defaults.c
+++ b/defaults.c
@@ -46,6 +46,8 @@ const struct fw3_option fw3_flag_opts[]
 	FW3_OPT("synflood_protect",    bool,     defaults, syn_flood),
 	FW3_OPT("synflood_rate",       limit,    defaults, syn_flood_rate),
 	FW3_OPT("synflood_burst",      int,      defaults, syn_flood_rate.burst),
+
+	FW3_OPT("fullcone",           bool,     defaults, fullcone),

 	FW3_OPT("tcp_syncookies",      bool,     defaults, tcp_syncookies),
 	FW3_OPT("tcp_ecn",             int,      defaults, tcp_ecn),
--- a/options.h
+++ b/options.h
@@ -267,6 +267,9 @@ struct fw3_defaults
 	bool drop_invalid;

 	bool syn_flood;
+	bool fullcone;
+
+#define FW3_FULLCONE_MAX 8
 	struct fw3_limit syn_flood_rate;

 	bool tcp_syncookies;
--- a/zones.c
+++ b/zones.c
@@ -627,6 +627,12 @@ print_zone_rule(struct fw3_ipt_handle *h
 	struct fw3_address *msrc;
 	struct fw3_address *mdest;
 	struct fw3_ipt_rule *r;
+	struct fw3_defaults *defs = &state->defaults;
+	bool zone_fullcone = false;
+	const char *fullcone_protos[FW3_FULLCONE_MAX] = {};
+	int n_fc_protos = 0;
+	const char *fullcone_srcs[FW3_FULLCONE_MAX] = {};
+	int n_fc_srcs = 0;

 	if (!fw3_is_family(zone, handle->family))
 		return;
@@ -634,6 +640,37 @@ print_zone_rule(struct fw3_ipt_handle *h
 	if (!fw3_is_family(zone, handle->family))
 		return;

+	/* Parse per-zone fullcone options from UCI.
+	 * defaults.fullcone is a global gate — when off, zone setting ignored.
+	 * When on, zone must explicitly set fullcone=1.
+	 */
+	{
+		struct uci_element *e;
+		struct uci_option *o;
+		const char *val;
+
+		if (defs->fullcone) {
+			val = uci_lookup_option_string(state->uci, zone->section, "fullcone");
+			zone_fullcone = val ? fw3_parse_bool(val) : false;
+		}
+
+		o = uci_lookup_option(state->uci, zone->section, "fullcone_proto");
+		if (o && o->type == UCI_TYPE_LIST) {
+			uci_foreach_element(&o->v.list, e) {
+				if (n_fc_protos < FW3_FULLCONE_MAX)
+					fullcone_protos[n_fc_protos++] = e->name;
+			}
+		}
+
+		o = uci_lookup_option(state->uci, zone->section, "fullcone_src");
+		if (o && o->type == UCI_TYPE_LIST) {
+			uci_foreach_element(&o->v.list, e) {
+				if (n_fc_srcs < FW3_FULLCONE_MAX)
+					fullcone_srcs[n_fc_srcs++] = e->name;
+			}
+		}
+	}
+
 	switch (handle->table)
 	{
 	case FW3_TABLE_FILTER:
@@ -712,9 +749,52 @@ print_zone_rule(struct fw3_ipt_handle *h
 				{
 					r = fw3_ipt_rule_new(handle);
 					fw3_ipt_rule_src_dest(r, msrc, mdest);
-					fw3_ipt_rule_target(r, "MASQUERADE");
-					fw3_ipt_rule_append(r, "zone_%s_postrouting", zone->name);
+					if (zone_fullcone && (n_fc_protos > 0 || n_fc_srcs > 0))
+					{
+						int p, s;
+						/* Emit fullcone rules with proto/src filtering */
+						if (n_fc_protos > 0) {
+							for (p = 0; p < n_fc_protos; p++) {
+								r = fw3_ipt_rule_new(handle);
+								fw3_ipt_rule_src_dest(r, msrc, mdest);
+								fw3_ipt_rule_proto(r, fullcone_protos[p]);
+								for (s = 0; s < n_fc_srcs; s++)
+									fw3_ipt_rule_extra(r, "-s %s", fullcone_srcs[s]);
+								fw3_ipt_rule_target(r, "MASQUERADE");
+								fw3_ipt_rule_extra(r, "--fullcone");
+								fw3_ipt_rule_append(r, "zone_%s_postrouting", zone->name);
+							}
+						} else {
+							/* src-only, no proto filter */
+							for (s = 0; s < n_fc_srcs; s++) {
+								r = fw3_ipt_rule_new(handle);
+								fw3_ipt_rule_src_dest(r, msrc, mdest);
+								fw3_ipt_rule_extra(r, "-s %s", fullcone_srcs[s]);
+								fw3_ipt_rule_target(r, "MASQUERADE");
+								fw3_ipt_rule_extra(r, "--fullcone");
+								fw3_ipt_rule_append(r, "zone_%s_postrouting", zone->name);
+							}
+						}
+						/* Fallback: everything else gets standard masquerade */
+						r = fw3_ipt_rule_new(handle);
+						fw3_ipt_rule_src_dest(r, msrc, mdest);
+						fw3_ipt_rule_target(r, "MASQUERADE");
+						fw3_ipt_rule_append(r, "zone_%s_postrouting", zone->name);
+					}
+					else if (zone_fullcone)
+					{
+						/* All traffic fullcone */
+						fw3_ipt_rule_target(r, "MASQUERADE");
+						fw3_ipt_rule_extra(r, "--fullcone");
+						fw3_ipt_rule_append(r, "zone_%s_postrouting", zone->name);
+					}
+					else
+					{
+						/* Standard masquerade */
+						fw3_ipt_rule_target(r, "MASQUERADE");
+						fw3_ipt_rule_append(r, "zone_%s_postrouting", zone->name);
+					}
 				}
 			}
 		}
