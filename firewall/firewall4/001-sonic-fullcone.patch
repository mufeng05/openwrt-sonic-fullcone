--- /dev/null
+++ b/root/usr/share/firewall4/templates/zone-fullcone.uc
@@ -0,0 +1,10 @@
+{# /usr/share/firewall4/templates/zone-fullcone.uc
+   proto:  string (L4 protocol name) or null
+   fc_src: array of pre-formatted IP/CIDR strings or null
+ #}
+		meta nfproto {{ fw4.nfproto(family) }}{{
+		(fc_src && length(fc_src)) ? ` ${family == 6 ? 'ip6' : 'ip'} saddr { ${join(', ', fc_src)} }` : ''
+		}}{{
+		proto ? ` meta l4proto ${proto}` : ''
+		}} fullcone comment "!fw4: {{ zone.name }} {{ fw4.nfproto(family, true) }} fullcone{{
+		proto ? ` ${proto}` : '' }} NAT {{ direction }}"
--- a/root/usr/share/ucode/fw4.uc
+++ b/root/usr/share/ucode/fw4.uc
@@ -489,6 +489,25 @@ function nft_try_hw_offload(devices) {
 	return (rc == 0);
 }

+function nft_try_fullcone() {
+	let nft_test =
+		'add table inet fw4-fullcone-test; ' +
+		'add chain inet fw4-fullcone-test dstnat { ' +
+			'type nat hook prerouting priority -100; policy accept; ' +
+			'fullcone; ' +
+		'}; ' +
+		'add chain inet fw4-fullcone-test srcnat { ' +
+			'type nat hook postrouting priority -100; policy accept; ' +
+			'fullcone; ' +
+		'}; ';
+	let cmd = sprintf("/usr/sbin/nft -c '%s' 2>/dev/null", replace(nft_test, "'", "'\\''"));
+	let ok = system(cmd) == 0;
+	if (!ok) {
+		warn("nft_try_fullcone: fullcone expression not available in kernel\n");
+	}
+	return ok;
+}
+

 return {
 	read_kernel_version: function() {
@@ -1475,6 +1494,7 @@ return {
 			"dnat",
 			"snat",
 			"masquerade",
+			"fullcone",
 			"accept",
 			"reject",
 			"drop"
@@ -1946,6 +1966,7 @@ return {
 		}

 		let defs = this.parse_options(data, {
+			fullcone: [ "bool", "0" ],
 			input: [ "policy", "drop" ],
 			output: [ "policy", "drop" ],
 			forward: [ "policy", "drop" ],
@@ -1980,6 +2002,13 @@ return {

 		delete defs.syn_flood;

+		if (defs.fullcone) {
+			if (!nft_try_fullcone()) {
+				delete defs.fullcone;
+				warn("fullcone expression not available, disabling fullcone globally\n");
+			}
+		}
+
 		this.state.defaults = defs;
 	},

@@ -2034,3 +2055,7 @@ return {
 			masq6: [ "bool" ],

+			fullcone: [ "bool" ],
+			fullcone_proto: [ "protocol", null, PARSE_LIST ],
+			fullcone_src: [ "network", null, PARSE_LIST ],
+
 			extra: [ "string", null, UNSUPPORTED ],
@@ -2149,6 +2179,51 @@ return {
 			}
 		}

+		/* SONiC fullcone: defaults.fullcone is a global gate.
+		 * When off, all fullcone is disabled regardless of zone config.
+		 * When on, each zone must explicitly set fullcone=1 to enable.
+		 *
+		 * Flatten fullcone_proto (list of protocol objects) into plain
+		 * name strings, and fullcone_src (list of network objects, each
+		 * with .addrs array) into per-family lists of formatted strings
+		 * suitable for direct use in nftables templates.
+		 */
+		zone.fullcone = !!(this.state.defaults.fullcone && zone.fullcone);
+		zone.fullcone6 = zone.fullcone;
+
+		if (zone.fullcone_proto && length(zone.fullcone_proto)) {
+			let names = [];
+			for (let p in zone.fullcone_proto) {
+				if (!p || p.any || !p.name)
+					continue;
+				push(names, p.name);
+			}
+			zone.fullcone_proto = length(names) ? names : null;
+		} else {
+			zone.fullcone_proto = null;
+		}
+
+		if (zone.fullcone_src && length(zone.fullcone_src)) {
+			let v4 = [], v6 = [];
+			for (let net in zone.fullcone_src) {
+				if (!net || !net.addrs)
+					continue;
+				for (let a in net.addrs) {
+					if (!a)
+						continue;
+					if (a.family == 4)
+						push(v4, this.cidr(a));
+					else if (a.family == 6)
+						push(v6, this.cidr(a));
+				}
+			}
+			zone.fullcone_src4 = length(v4) ? v4 : null;
+			zone.fullcone_src6 = length(v6) ? v6 : null;
+		} else {
+			zone.fullcone_src4 = null;
+			zone.fullcone_src6 = null;
+		}
+
 		if (zone.mtu_fix && this.kernel < 0x040a0000) {
 			this.warn_section(data, "option mtu_fix requires kernel 4.10 or later, ignoring");
 			return;
@@ -2205,11 +2265,22 @@ return {
 		zone.related_subnets = related_subnets;
 		zone.related_physdevs = related_physdevs;

-		if (zone.masq || zone.masq6)
+		if (zone.masq) {
 			zone.dflags.snat = true;
+			if (zone.fullcone)
+				zone.dflags.dnat = true;
+		}
+
+		if (zone.masq6) {
+			zone.dflags.snat = true;
+			if (zone.fullcone6)
+				zone.dflags.dnat = true;
+		}

-		if ((zone.auto_helper && !(zone.masq || zone.masq6)) || length(zone.helper)) {
+		if ((zone.auto_helper && !(zone.masq || zone.masq6 ||
+		     zone.fullcone || zone.fullcone6)) ||
+		    length(zone.helper)) {
 			zone.dflags.helper = true;

 			for (let helper in (length(zone.helper) ? zone.helper : this.state.helpers)) {
