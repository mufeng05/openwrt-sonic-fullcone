From: openwrt-sonic-fullcone contributors
Date: Wed, 9 Apr 2026 00:00:00 +0000
Subject: [PATCH] luci-app-firewall: add SONiC fullcone NAT options

Add fullcone NAT configuration to the firewall web interface:

  - Global "Fullcone NAT" checkbox in General Settings (defaults section)
  - Per-zone "Fullcone NAT" checkbox in zone General tab (next to Masquerading)
  - Per-zone "Fullcone protocols" multi-value in zone Advanced tab
  - Per-zone "Fullcone source IPs" dynamic list in zone Advanced tab

These options map to UCI:
  firewall.@defaults[0].fullcone=1
  firewall.@zone[N].fullcone=1
  firewall.@zone[N].fullcone_proto='udp' 'tcp'
  firewall.@zone[N].fullcone_src='192.168.1.100' '192.168.1.200'
---
 .../resources/view/firewall/zones.js          | 54 +++++++++++++++++++
 1 file changed, 54 insertions(+)

--- a/htdocs/luci-static/resources/view/firewall/zones.js
+++ b/htdocs/luci-static/resources/view/firewall/zones.js
@@ -70,6 +70,12 @@
 		o = s.option(form.Flag, 'drop_invalid', _('Drop invalid packets'));
 		o.default = fwDefaults.getDropInvalid();

+		o = s.option(form.Flag, 'fullcone', _('Fullcone NAT'),
+			_('Enable SONiC-style fullcone NAT globally for all zones with masquerading. Can be overridden per-zone.'));
+		o.default = '0';
+		o.rmempty = true;
+		o.optional = true;
+
 		var p = [ 'input', 'output', 'forward' ];

 		for (var i = 0; i < p.length; i++) {
@@ -161,6 +167,25 @@
 			return null;
 		};

+		o = s.taboption('general', form.Flag, 'fullcone', _('Fullcone NAT'),
+			_('Enable SONiC-style fullcone NAT for this zone. When enabled alongside masquerading, ' +
+			  'provides RFC 3489 full cone NAT behavior. Use "Fullcone protocols" and "Fullcone source IPs" ' +
+			  'in Advanced Settings to restrict scope.'));
+		o.editable = true;
+		o.depends('masq', '1');
+		o.modalonly = false;
+
 		o = s.taboption('general', form.Flag, 'mtu_fix', _('MSS clamping'));
 		o.modalonly = true;

@@ -239,6 +264,35 @@
 		if (fw4)
 			o.modalonly = true;

+		o = s.taboption('advanced', form.MultiValue, 'fullcone_proto',
+			_('Fullcone protocols'),
+			_('Restrict fullcone NAT to specific L4 protocols. ' +
+			  'When empty, all protocols use fullcone. ' +
+			  'Recommended: select only UDP for gaming/P2P use cases.'));
+		o.value('tcp', _('TCP'));
+		o.value('udp', _('UDP'));
+		o.value('udplite', _('UDP-Lite'));
+		o.value('sctp', _('SCTP'));
+		o.value('dccp', _('DCCP'));
+		o.depends('fullcone', '1');
+		o.modalonly = true;
+		o.optional = true;
+		o.placeholder = _('All protocols');
+		o.display_size = 5;
+		o.delimiter = ' ';
+
+		o = s.taboption('advanced', form.DynamicList, 'fullcone_src',
+			_('Fullcone source IPs'),
+			_('Restrict fullcone NAT to specific LAN source IP addresses or CIDR subnets. ' +
+			  'When empty, all source IPs use fullcone. ' +
+			  'Example: 192.168.1.100 or 192.168.1.0/24'));
+		o.depends('fullcone', '1');
+		o.modalonly = true;
+		o.optional = true;
+		o.datatype = 'or(ipaddr,cidr4)';
+		o.placeholder = _('All source IPs');
+
 		o = s.taboption('advanced', form.ListValue, 'family', _('Restrict to address family'));
 		o.value('', _('IPv4 and IPv6'));
 		o.value('ipv4', _('IPv4 only'));
